{
  "name": "blip-mcp",
  "version": "0.1.1",
  "description": "Visual annotation MCP server for Claude Code - draw on preview screenshots to communicate UI changes",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "blip": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "serve": "node dist/dev-server.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "blip",
    "claude",
    "claude-code",
    "annotation",
    "screenshot",
    "visual-feedback",
    "model-context-protocol",
    "ai-coding"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nebenzu/Blip"
  },
  "files": [
    "dist",
    "public",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
